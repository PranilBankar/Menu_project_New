APP_NAME="Menu Intelligence System"
APP_VERSION="1.0.0"
DEBUG=True

# ============================================================================
# SUPABASE DATABASE CONFIGURATION (Hosted PostgreSQL)
# ============================================================================
# 
# Get your connection string from Supabase Dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings → Database
# 4. Copy the "URI" connection string
# 
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# 
# IMPORTANT: Add ?sslmode=require at the end for secure connection
# ----------------------------------------------------------------------------

DATABASE_URL=postgresql://postgres:SuhaPra@20065@db.pirxrfkrjgskjjacrnkr.supabase.co:5432/postgres?sslmode=require
# Example (replace with your actual values):
# DATABASE_URL=postgresql://postgres:MySecurePass123!@db.abcdefghijklmnop.supabase.co:5432/postgres?sslmode=require

DB_ECHO=False

# ============================================================================
# SUPABASE PROJECT DETAILS (Optional - for future features)
# ============================================================================
# Get these from Supabase Dashboard → Settings → API
# ----------------------------------------------------------------------------

SUPABASE_URL=hhttps://pirxrfkrjgskjjacrnkr.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBpcnhyZmtyamdza2pqYWNybmtyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjkzODc0NTgsImV4cCI6MjA4NDk2MzQ1OH0.0G-EA2HB4Vb3xc1W-0N5qh94YUmo3AuIs5FT2scYo2c
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBpcnhyZmtyamdza2pqYWNybmtyIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2OTM4NzQ1OCwiZXhwIjoyMDg0OTYzNDU4fQ.w6-WBmBLg0DZxXEUWhSlAGRwR8cqp3d-Ge0tPawPLCQ

# ============================================================================
# REDIS CONFIGURATION (Optional - for caching in Phase 4)
# ============================================================================
# For now, you can use a free Redis service like:
# - Upstash: https://upstash.com (Free tier available)
# - Redis Cloud: https://redis.com/try-free
# Or leave as localhost if running Redis locally
# ----------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Generate a secure secret key using:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# ----------------------------------------------------------------------------

SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# OCR CONFIGURATION
# ============================================================================
# OCR_ENGINE options: "paddleocr" (free, local) or "google_vision" (paid, cloud)
# For Google Vision, get API key from: https://console.cloud.google.com
# ----------------------------------------------------------------------------

OCR_ENGINE=paddleocr
GOOGLE_VISION_API_KEY=

# ============================================================================
# LLM CONFIGURATION (For Menu Structuring)
# ============================================================================
# Get OpenAI API key from: https://platform.openai.com/api-keys
# 
# Recommended models:
# - gpt-4-turbo-preview (best accuracy, higher cost)
# - gpt-3.5-turbo (good accuracy, lower cost)
# 
# If you don't have an API key, the system will use rule-based fallback
# ----------------------------------------------------------------------------

OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.3

# ============================================================================
# EMBEDDINGS CONFIGURATION (For Phase 2 - Semantic Search)
# ============================================================================
# sentence-transformers/all-MiniLM-L6-v2 is recommended (384 dimensions)
# Other options:
# - sentence-transformers/all-mpnet-base-v2 (768 dimensions, more accurate)
# - sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (multilingual)
# ----------------------------------------------------------------------------

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
# UPLOAD_DIR: Local directory for storing uploaded menu images
# MAX_UPLOAD_SIZE: Maximum file size in bytes (10MB = 10485760)
# ALLOWED_EXTENSIONS: Comma-separated list of allowed file extensions
# ----------------------------------------------------------------------------

UPLOAD_DIR=data/raw
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.pdf
HUGGINGFACE_API_KEY=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
LLM_PROVIDER=huggingface
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
LLM_TEMPERATURE=0.3

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Add your frontend URLs here (comma-separated)
# For production, replace with your actual domain
# ----------------------------------------------------------------------------

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. NEVER commit this file to Git (already in .gitignore)
# 2. Copy this file to .env and fill in your actual values
# 3. For Supabase setup instructions, see: SUPABASE_SETUP.md
# 4. For local development, you can leave Redis and some optional fields empty
# 5. Minimum required: DATABASE_URL and OPENAI_API_KEY (for best results)
# 
# ============================================================================
